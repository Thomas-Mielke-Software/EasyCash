<?xml version="1.0" encoding="utf-8"?>
<!--
  EasyCT.exe.config — Laufzeitkonfiguration für Mixed-Mode-Assembly-Unterstützung

  Diese Datei muss NEBEN der EasyCT.exe liegen (im Debug/Release-Verzeichnis).
  Sie wird benötigt, weil ECTBridge.dll eine Mixed-Mode-Assembly ist (/clr),
  die von einer nativen EXE geladen wird. Ohne diese Config kann der CLR-Loader
  eine BadImageFormatException oder MixedModeException werfen.

  useLegacyV2RuntimeActivationPolicy="true" ist erforderlich, damit die CLR v4
  auch gemischt native/managed-DLLs laden kann, die gegen ältere .NET-Versionen
  gebaut wurden.
-->
<configuration>
  <startup useLegacyV2RuntimeActivationPolicy="true">
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
</configuration>

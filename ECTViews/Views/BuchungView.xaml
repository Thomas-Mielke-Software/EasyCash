<Window x:Class="ECTViews.Views.BuchungView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ECTViews.Views"
        Title="{Binding BuchungsartText, StringFormat='Buchung ({0})'}"
        MinWidth="480" MinHeight="640"
        Width="800"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="#F5F5F5"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Basis-Stil für Labels -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <!-- Stil für Fehlertexte: rot, klein, verschwindet bei leerem Text -->
        <Style TargetType="TextBlock" x:Key="ErrorStyle">
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stil für Hinweistexte: blau-grau, klein, kursiv. Erkennbar
             abgesetzt von den roten Validierungsfehlern. Wird z.B. zur
             AfA-Restwert-Heuristik verwendet. -->
        <Style TargetType="TextBlock" x:Key="HintStyle">
            <Setter Property="Foreground" Value="#0277BD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Stil für Eingabefelder -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- Gruppenbox-Stil -->
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Konverter: bool → Visibility (Collapsed bei false) -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- DataTemplate für Icon-Listen-Items: Icon links, Name rechts.
             Stretch="Uniform" skaliert das gecroppte Icon proportional auf
             die Image-Größe — funktioniert egal ob die Quell-Sprites 16x16,
             32x32 oder andere Größen verwenden. -->
        <DataTemplate x:Key="IconItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Icon}" Width="32" Height="32"
                       Margin="0,0,8,0" Stretch="Uniform"
                       VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Buchungsart -->
            <RowDefinition Height="Auto"/>  <!-- Datum -->
            <RowDefinition Height="Auto"/>  <!-- Betrag + MWSt -->
            <RowDefinition Height="Auto"/>  <!-- Beschreibung -->
            <RowDefinition Height="Auto"/>  <!-- Belegnummer + Konto -->
            <RowDefinition Height="Auto"/>  <!-- Bestandskonto + Betrieb -->
            <RowDefinition Height="Auto"/>  <!-- AfA -->
            <RowDefinition Height="*"/>     <!-- Spacer -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══ Zeile 0: Buchungsart ═══ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton Content="Einnahme" FontWeight="SemiBold"
                         IsChecked="{Binding IstEinnahme}"
                         Foreground="#2E7D32" Margin="0,0,16,0"
                         VerticalContentAlignment="Center"/>
            <RadioButton Content="Ausgabe" FontWeight="SemiBold"
                         IsChecked="{Binding IstAusgabe}"
                         Foreground="#C62828"
                         VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- ═══ Zeile 1: Datum ═══ -->
        <GroupBox Grid.Row="1" Header="Datum">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tag:" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding DatumTag, UpdateSourceTrigger=PropertyChanged}"
                             Width="40" MaxLength="2" TextAlignment="Center"/>
                    <TextBlock Text="." VerticalAlignment="Center" Margin="2,0"/>
                    <TextBlock Text="Monat:" Style="{StaticResource LabelStyle}" Margin="8,0,8,0"/>
                    <TextBox Text="{Binding DatumMonat, UpdateSourceTrigger=PropertyChanged}"
                             Width="40" MaxLength="2" TextAlignment="Center"/>
                    <TextBlock Text="." VerticalAlignment="Center" Margin="2,0"/>
                    <TextBlock Text="Jahr:" Style="{StaticResource LabelStyle}" Margin="8,0,8,0"/>
                    <TextBox Text="{Binding DatumJahr, UpdateSourceTrigger=PropertyChanged}"
                             Width="60" MaxLength="4" TextAlignment="Center"/>
                </StackPanel>
                <TextBlock Style="{StaticResource ErrorStyle}"
                           Text="{Binding DatumError}"/>
            </StackPanel>
        </GroupBox>

        <!-- ═══ Zeile 2: Betrag + MWSt ═══ -->
        <GroupBox Grid.Row="2" Header="Betrag">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Bruttobetrag -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Brutto (€):" Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding BetragText, UpdateSourceTrigger=PropertyChanged}"
                         TextAlignment="Right" FontWeight="SemiBold" FontSize="15"/>

                <!-- MWSt -->
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="MWSt %:" Style="{StaticResource LabelStyle}" Margin="12,0,8,0"/>
                <CheckBox Grid.Row="0" Grid.Column="3"
                          IsChecked="{Binding MwstAktiviert}"
                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox Grid.Row="0" Grid.Column="4"
                          Text="{Binding MwstText, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding MwstOptionen}"
                          IsEditable="True"
                          IsEnabled="{Binding MwstAktiviert}"
                          HorizontalContentAlignment="Right"/>

                <!-- Netto / USt Anzeige -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Netto:" Style="{StaticResource LabelStyle}"
                           Foreground="#888"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding NettoText}" TextAlignment="Right"
                           VerticalAlignment="Center" Foreground="#888" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                           Text="USt:" Style="{StaticResource LabelStyle}"
                           Foreground="#888" Margin="12,0,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="4"
                           Text="{Binding MwstBetragText}" TextAlignment="Right"
                           VerticalAlignment="Center" Foreground="#888" Margin="0,2"/>

                <!-- Fehler-Zeilen -->
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                           Style="{StaticResource ErrorStyle}"
                           Text="{Binding BetragError}"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5"
                           Style="{StaticResource ErrorStyle}"
                           Text="{Binding MwstError}"/>
            </Grid>
        </GroupBox>

        <!-- ═══ Zeile 3: Beschreibung ═══ -->
        <GroupBox Grid.Row="3" Header="Beschreibung">
            <StackPanel>
                <ComboBox Text="{Binding Beschreibung, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding BeschreibungsHistorie}"
                          IsEditable="True"/>
                <TextBlock Style="{StaticResource ErrorStyle}"
                           Text="{Binding BeschreibungError}"/>
            </StackPanel>
        </GroupBox>

        <!-- ═══ Zeile 4: Belegnummer + Konto ═══ -->
        <GroupBox Grid.Row="4" Header="Zuordnung">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Beleg-Nr.:"
                           Style="{StaticResource LabelStyle}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding Belegnummer, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="2" Text="Konto:"
                           Style="{StaticResource LabelStyle}" Margin="12,0,8,0"/>
                <ComboBox Grid.Column="3"
                          Text="{Binding SelectedKonto, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding Konten}"
                          IsEditable="True"/>
            </Grid>
        </GroupBox>

        <!-- ═══ Zeile 5: Bestandskonto + Betrieb (mit Icon-Listen) ═══ -->
        <Grid Grid.Row="5"
              Visibility="{Binding ListenAnzeigen, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Bestandskonto"
                      Visibility="{Binding BestandskontenAnzeigen,
                                   Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <local:ListBoxScroll ItemsSource="{Binding Bestandskonten}"
                                   SelectedItem="{Binding SelectedBestandskonto}"
                                   ItemTemplate="{StaticResource IconItemTemplate}"
                                   Height="160"
                                   ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Style="{StaticResource ErrorStyle}"
                               Text="{Binding BestandskontoError}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Betrieb"
                      Visibility="{Binding BetriebeAnzeigen,
                                   Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <ListBox ItemsSource="{Binding Betriebe}"
                             SelectedItem="{Binding SelectedBetrieb}"
                             ItemTemplate="{StaticResource IconItemTemplate}"
                             Height="160"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Style="{StaticResource ErrorStyle}"
                               Text="{Binding BetriebError}"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- ═══ Zeile 6: Abschreibung ═══ -->
        <GroupBox Grid.Row="6" Header="Abschreibung (AfA)">
            <StackPanel>
                <CheckBox Content="Abschreibung aktivieren"
                          IsChecked="{Binding AfaAktiviert}"
                          Margin="0,0,0,6"/>
                <Grid IsEnabled="{Binding AfaAktiviert}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Jahre:"
                               Style="{StaticResource LabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Text="{Binding AfaJahre}"
                              ItemsSource="{Binding AfaJahreOptionen}"
                              IsEditable="True"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Nr.:"
                               Style="{StaticResource LabelStyle}" Margin="12,0,8,0"/>
                    <TextBox Grid.Row="0" Grid.Column="3"
                             Text="{Binding AfaNr}" TextAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Restwert:"
                               Style="{StaticResource LabelStyle}" Margin="12,0,8,0"/>
                    <TextBox Grid.Row="0" Grid.Column="5"
                             Text="{Binding AfaRestwertText, UpdateSourceTrigger=LostFocus}"
                             TextAlignment="Right"/>

                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Degressiv"
                              IsChecked="{Binding AfaDegressiv}" Margin="0,4,0,0"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Satz %:"
                               Style="{StaticResource LabelStyle}" Margin="12,0,8,0"/>
                    <TextBox Grid.Row="1" Grid.Column="3"
                             Text="{Binding AfaSatz}" TextAlignment="Center"
                             IsEnabled="{Binding AfaDegressiv}"/>
                </Grid>
                <TextBlock Style="{StaticResource ErrorStyle}"
                           Text="{Binding AfaError}"/>
                <TextBlock Style="{StaticResource HintStyle}"
                           Text="{Binding AfaHinweis}"/>
            </StackPanel>
        </GroupBox>

        <!-- ═══ Zeile 8: Buttons ═══ -->
        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{Binding OkButtonText}"
                    Command="{Binding OkCommand}"
                    Width="100" Height="32"
                    IsDefault="True" FontWeight="SemiBold"
                    Background="#1976D2" Foreground="White"
                    BorderThickness="0" Margin="0,0,8,0"/>
            <Button Content="Abbrechen"
                    Command="{Binding AbbrechenCommand}"
                    Width="100" Height="32"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

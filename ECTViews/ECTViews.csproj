<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>ECTViews</RootNamespace>
    <AssemblyName>ECTViews</AssemblyName>
    <LangVersion>latest</LangVersion>
    <OutputType>Library</OutputType>
    <UseWPF>true</UseWPF>
    <Description>WPF/XAML-basierte Views für EasyCash&amp;Tax</Description>
    <Company>Thomas Mielke Software</Company>
    <Copyright>Copyleft (GPLv3) 2024 Thomas Mielke</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Views\ScrollIntoViewForListBox.cs" />
  </ItemGroup>

  <!-- Sprite-Bitmaps für Betrieb/Bestandskonto-Icons als WPF-Ressourcen.
       Werden zur Laufzeit über pack://-URI geladen. Die Dateien müssen
       im Projektverzeichnis unter Resources/ liegen — am einfachsten
       per Kopie aus dem alten EasyCash-Hauptprojekt. -->
  <ItemGroup>
    <EmbeddedResource Include="Resources\icons.bmp" Condition="Exists('Resources\icons.bmp')" />
    <EmbeddedResource Include="Resources\icons_bestandskonten.bmp" Condition="Exists('Resources\icons_bestandskonten.bmp')" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ECTEngine\ECTEngine.csproj" />
  </ItemGroup>

</Project>
